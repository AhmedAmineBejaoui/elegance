{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",

  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs@18.17.0"
    }
  },

  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
